# PuffyCalm local development — copy to .env
# cp .env.example .env

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-production-min-32-chars!!
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Postgres (Docker Compose service name: postgres) ---
POSTGRES_USER=puffycalm
POSTGRES_PASSWORD=puffycalm_dev
POSTGRES_DB=puffycalm
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://puffycalm:puffycalm_dev@postgres:5432/puffycalm

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Ports ---
API_PORT=8000
GATEWAY_PORT=8080

# --- Auth admin (Phase 4) — change in production ---
ADMIN_EMAIL=admin@puffycalm.com
ADMIN_PASSWORD=changeme-admin-dev
ADMIN_FULL_NAME=PuffyCalm Admin
STAFF_EMAIL=staff@puffycalm.com
STAFF_PASSWORD=changeme-staff-dev
STAFF_FULL_NAME=PuffyCalm Staff
# ACCESS_TOKEN_MINUTES=15
# REFRESH_TOKEN_DAYS=7
# COOKIE_SECURE=false   # auto false in development
# COOKIE_SAMESITE=lax

# --- Frontend (optional, Phase 9) ---
# NEXT_PUBLIC_API_URL=http://localhost:8080
# Browser admin: fetch(API, { credentials: "include" }) after login cookies

# --- Stripe (backend only for secret; never commit real values) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from: stripe listen --print-secret
# STRIPE_API_VERSION=2025-03-31.basil
# STOREFRONT_URL=http://localhost:3000
# FREE_SHIPPING_THRESHOLD_CENTS=7500
# FLAT_SHIPPING_CENTS=699
# Publishable key goes in FE .env.local as NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
