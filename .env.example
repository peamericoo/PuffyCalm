# PuffyCalm local development — copy to .env
# cp .env.example .env

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-production-min-32-chars!!
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Postgres (Docker Compose service name: postgres) ---
POSTGRES_USER=puffycalm
POSTGRES_PASSWORD=puffycalm_dev
POSTGRES_DB=puffycalm
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://puffycalm:puffycalm_dev@postgres:5432/puffycalm

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Ports ---
API_PORT=8000
GATEWAY_PORT=8080

# --- Auth admin (Phase 4 + Phase E) — change in production ---
ADMIN_EMAIL=admin@puffycalm.com
ADMIN_PASSWORD=changeme-admin-dev
ADMIN_FULL_NAME=PuffyCalm Admin
STAFF_EMAIL=staff@puffycalm.com
STAFF_PASSWORD=changeme-staff-dev
STAFF_FULL_NAME=PuffyCalm Staff
# Phase E1 — Google → JWT cookies (comma-separated allowlists; no secrets)
# ADMIN_EMAILS=paletot.business@gmail.com
# STAFF_EMAILS=
# Same Web client ID as AUTH_GOOGLE_ID on Next.js (audience for ID token)
# GOOGLE_CLIENT_ID=
# Cross-origin admin cookies (Railway web host ≠ api host):
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true
# ACCESS_TOKEN_MINUTES=15
# REFRESH_TOKEN_DAYS=7
# COOKIE_SECURE=false   # auto false in development
# COOKIE_SAMESITE=lax

# --- Frontend (optional, Phase 9) ---
# NEXT_PUBLIC_API_URL=http://localhost:8080
# Browser admin: fetch(API, { credentials: "include" }) after google-exchange

# --- Stripe (backend only for secret; never commit real values) ---
# Full prod checklist (no secrets): docs/ops/ENV_CHECKLIST.md
# Contracts (shipping + checkout): docs/ops/CONTRACTS.md
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from: stripe listen --print-secret
# STRIPE_API_VERSION=2025-03-31.basil
# STOREFRONT_URL=http://localhost:3000
# Canonical business rates (use in local/prod after smoke ends — Fase D):
# FREE_SHIPPING_THRESHOLD_CENTS=7500
# FLAT_SHIPPING_CENTS=699
# Smoke prod_009 ($0.50): set both to 0 on API so charge stays at Stripe minimum
# Publishable key goes in FE .env.local as NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY

# --- Media / object storage (Phase I) — Railway S3-compatible bucket ---
# Prefer Railway: `railway bucket credentials --bucket <name>`
# Railway buckets are PRIVATE — public image URLs go through API GET /media/{key}.
# When S3_* unset, API uses local filesystem under MEDIA_LOCAL_DIR (dev only).
# S3_ENDPOINT_URL=https://t3.storageapi.dev
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
# Public base stored in product_images (must be the API media proxy, not the raw bucket host):
# S3_PUBLIC_BASE_URL=http://localhost:8000/media
# Prod example: https://api-production-4f01.up.railway.app/media
# MEDIA_MAX_BYTES=5242880
# MEDIA_LOCAL_DIR=uploads
# MEDIA_LOCAL_PUBLIC_BASE_URL=http://localhost:8000/media
