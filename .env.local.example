# Storefront Auth.js + Google OAuth (copy to .env.local)
# Free Google Cloud OAuth client — no paid APIs required.

AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Application type: Web application
# Authorized JavaScript origins:
#   http://localhost:3000
#   https://web-production-ea635.up.railway.app
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://web-production-ea635.up.railway.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Super-admin Google account (FE UX allowlist only — real barrier is API ADMIN_EMAILS)
ADMIN_EMAIL=paletot.business@gmail.com
# STAFF_EMAILS=ops@example.com

# Phase E: NEXT_PUBLIC_API_URL must point at FastAPI; admin calls use credentials:include
# API also needs ADMIN_EMAILS + GOOGLE_CLIENT_ID (= AUTH_GOOGLE_ID) — see docs/ops/ENV_CHECKLIST.md

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=PuffyCalm

# Stripe (test mode) — publishable only on the frontend
# Secret key lives ONLY on the FastAPI backend (backend/.env / Railway api)
# Ops checklist: docs/ops/ENV_CHECKLIST.md
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8080

# Phase M — domain catalog/reviews/search always from FastAPI (no mock rollback).
# NEXT_PUBLIC_USE_API_CATALOG is ignored if set.

